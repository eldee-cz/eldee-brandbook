---
import Layout from '../../components/Layout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import LogoVariant from '../../components/LogoVariant.astro';
import AssetDownload from '../../components/AssetDownload.astro';
---
<Layout title="Logo System" section="07 · LOGO">
  <SectionTitle
    number="07 · LOGO SYSTEM"
    title="Tři vrstvy log"
    subtitle="Wordmark pro marketing, LD monogram pro vyšívání, hole pattern pro produkt."
  />

  <section class="mb-16">
    <h2 class="font-display text-h2 text-bone mb-2">Vrstva 1 — Wordmark</h2>
    <p class="text-body-lg text-bone/70 mb-6 max-w-2xl">Hlavní logo eldee — wordmark <strong>v2 (lockup L3)</strong>: slovo „eldee" s <strong>vnořeným interlock monogramem LD</strong> a zlatou svatozáří. Monogram není vedle slova, je doslova <strong>vyříznutý z něj</strong> — sub-mark a wordmark jsou jedna rodina. Blok LD + svatozář je vycentrovaný na osu malých „e", D podsedá pod baseline. Big Shoulders Display Black, bez sklonu. Pro web, IG, krabičky, vizitky, podcast cover.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      <LogoVariant src="/logo/wordmark-light.svg" alt="eldee wordmark on black" bg="ink"   caption="Na tmavém pozadí" />
      <LogoVariant src="/logo/wordmark-dark.svg"  alt="eldee wordmark on bone"  bg="bone"  caption="Na světlém pozadí" />
      <LogoVariant src="/logo/wordmark-light.svg" alt="eldee wordmark on blood" bg="blood" caption="Na blood red" />
      <LogoVariant src="/logo/wordmark-light.svg" alt="eldee wordmark on gold"  bg="gold"  caption="Na gold (Holy edice)" />
    </div>
  </section>

  <section class="mb-16">
    <h2 class="font-display text-h2 text-bone mb-2">Vrstva 2 — LD Monogram</h2>
    <p class="text-body-lg text-bone/70 mb-6 max-w-2xl">Monogram <strong>LD v2.1</strong> z fontu Big Shoulders Display Black — <strong>interlock</strong>: „L" proniká skrz „D" a obě písmena tvoří <strong>jedno srostlé těleso</strong> (eldee rodina drží pohromadě). „D" je dominantní, „L" posazené mírně výš. Nad „D" se vznáší <strong>zlatá svatozář</strong> (odkaz na Holy Socks) — kompozice N2. V průniku písmen je průhledná knockout spára, takže monogram je čitelný na světlém i tmavém pozadí. <strong>Logo je navržené jehlou:</strong> každý tah, spára i prsten svatozáře drží minimální tloušťky pro vyšití při nášivce 35 mm. Existuje proto <strong>jediná podoba monogramu</strong> — co vidíš na štulpně, vidíš i na webu, vizitce a krabičce.</p>
    <div class="grid md:grid-cols-2 gap-4">
      <LogoVariant src="/logo/monogram-ld.svg" alt="LD monogram on black" bg="ink" showSafeZone={true} caption={'Clear space = výška „L“'} />
      <LogoVariant src="/logo/monogram-ld.svg" alt="LD monogram on blood" bg="blood" caption="Na blood red" />
    </div>
    <h3 class="font-display text-h3 text-bone mt-10 mb-2">Vyšívání (embroidery-first parametry)</h3>
    <p class="text-body-lg text-bone/70 mb-6 max-w-2xl">Master monogram je <strong>přímo vyšitelný</strong> — při nášivce 35 mm: tahy písmen 5,6 mm, <strong>spára 1,8 mm</strong>, prsten svatozáře <strong>1,6 mm</strong> s vnitřním otvorem 2,2 mm. Do vyšívárny nikdy neposílat SVG napřímo — vždy digitalizace přes digitizéra (PES/DST) + <strong>sew-out vzorek na úpletu</strong> před sérií. Mono varianta (currentColor) slouží pro jednobarevné aplikace.</p>
    <div class="grid md:grid-cols-2 gap-4">
      <LogoVariant src="/logo/monogram-mono.svg" alt="LD monogram mono on black" bg="ink" caption="Mono — currentColor" />
      <LogoVariant src="/logo/monogram-mono.svg" alt="LD monogram mono on blood" bg="blood" caption="Embroidery target — nášivka 35 mm" />
    </div>
  </section>

  <section class="mb-16">
    <h2 class="font-display text-h2 text-bone mb-2">Vrstva 3 — Hole Pattern</h2>
    <p class="text-body-lg text-bone/70 mb-6 max-w-2xl">Chráněný průmyslový vzor — 5×2 oválných děr. Primární vyšívaný motiv na lýtku.</p>
    <LogoVariant src="/logo/hole-pattern.svg" alt="Hole pattern" bg="ink" caption="5×2 grid, ovály 12×16 mm" />
  </section>

  <section class="mb-16">
    <h2 class="font-display text-h2 text-bone mb-2">Halo — sekundární symbol</h2>
    <p class="text-body-lg text-bone/70 mb-6 max-w-2xl">Svatozář v gold — alternativa k „koruně" z streetwear estetiky. Odkazuje na Holy Socks.</p>
    <LogoVariant src="/logo/halo.svg" alt="Halo gold" bg="ink" caption="Burnished Gold #C9A227" />
  </section>

  <section class="mb-16">
    <h2 class="font-display text-h2 text-bone mb-6">Pravidla</h2>
    <ul class="space-y-3 text-body-lg text-bone/85 max-w-2xl">
      <li>· <strong>Clear space</strong> = minimálně výška „L" — v monogramu i wordmarku</li>
      <li>· <strong>Minimum size</strong> = wordmark 24 px / 8 mm, monogram 16 px / 5 mm, hole pattern 40 px / 14 mm</li>
      <li>· <strong>Nikdy</strong> neměnit poměr stran, neflipovat, nezbarvit jinak než brand colors</li>
      <li>· <strong>Jedno logo</strong> — jediné povolené odvozeniny jsou barevné (primary / mono), nikdy tvarové. Žádné „web verze" ani „jemné varianty".</li>
      <li>· <strong>Vyšívání</strong> = master monogram + hole pattern, přes digitizéra (PES/DST). Vždy sew-out vzorek na úpletu.</li>
      <li>· <strong>Foil tisk</strong> = wordmark v gold (Holy edice na krabičkách)</li>
    </ul>
    <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6">
      <a href="/logo/iterations" class="font-mono text-caption text-gold hover:text-bone transition">→ ITERATIONS · 6 variant eLDee (work in progress)</a>
      <a href="/logo/misuse" class="font-mono text-caption text-blood hover:text-blood-light transition">→ LOGO MISUSE</a>
    </div>
  </section>

  <section>
    <h2 class="font-display text-h2 text-bone mb-6">Stáhnout</h2>
    <div class="grid md:grid-cols-2 gap-3">
      <AssetDownload href="/logo/wordmark-light.svg" label="Wordmark — light variant" format="SVG" />
      <AssetDownload href="/logo/wordmark-dark.svg"  label="Wordmark — dark variant"  format="SVG" />
      <AssetDownload href="/logo/monogram-ld.svg"    label="LD Monogram v2.1 — master"    format="SVG" />
      <AssetDownload href="/logo/monogram-mono.svg"  label="LD Monogram v2.1 — mono (currentColor)" format="SVG" />
      <AssetDownload href="/logo/hole-pattern.svg"   label="Hole Pattern"              format="SVG" />
      <AssetDownload href="/logo/halo.svg"           label="Halo"                      format="SVG" />
    </div>
  </section>

</Layout>
